# 阿里云认证（必填）
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret

# Telegram 通知配置（必填）
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# 检测间隔（秒），默认 60
CHECK_INTERVAL=60

# 启动失败重试次数，默认 3
RETRY_COUNT=3
# 重试间隔（秒），默认 30
RETRY_INTERVAL=30

# 同一实例通知冷却时间（秒），默认 300
NOTIFY_COOLDOWN=300

# 流量超额自动关机（默认启用）
TRAFFIC_SHUTDOWN_ENABLED=true
# 国内流量阈值（GB），默认 19
TRAFFIC_LIMIT_CHINA_GB=19
# 国外流量阈值（GB），默认 195
TRAFFIC_LIMIT_NON_CHINA_GB=195
# 流量检查间隔（秒），默认 300
TRAFFIC_CHECK_INTERVAL=300

# GCP 抢占式实例监控（默认关闭）
GCP_ENABLED=false
# GCP 项目 ID（必填）
GCP_PROJECT_ID=your-gcp-project-id
# GCP 服务账号密钥文件路径（推荐，尤其在 systemd 环境下）
# 将服务账号 JSON 保存为独立文件，如 /opt/aliyun-spot-manager/gcp-credentials.json
GCP_CREDENTIALS_FILE=
# GCP 服务账号密钥 JSON 内容（备选，不推荐在 systemd 下使用）
# systemd EnvironmentFile 不支持 JSON 多行值，优先使用 GCP_CREDENTIALS_FILE
GCP_CREDENTIALS_JSON=
# GCP 监控区域，逗号分隔（留空自动发现所有区域）
GCP_ZONES=

# 日志级别：debug/info/warn/error，默认 info
LOG_LEVEL=info
# 日志文件路径，留空输出到控制台
LOG_FILE=